}

model ProjectStage {
  id                   String    @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  projectId            String
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                 String
  expectedDeliveryDate DateTime?
  order                Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Building {
  id                   String        @id @default(cuid())
  workspaceId          String
  workspace            Workspace     @relation(fields: [workspaceId], references: [id])
  projectId            String
  project              Project       @relation(fields: [projectId], references: [id])
  name                 String
  numberOfFloors       Int
  unitsPerFloor        Int           @default(4)
  description          String?
  image                String?
  status               ProjectStatus
  constructionStage    String?
  expectedDeliveryDate DateTime?
  // Metadata
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  units Unit[]
}

enum UnitStatus {
  DISPONIBLE
  BLOQUEADA
  RESERVADA
  VENDIDA
  ENTREGADA
}

enum UnitView {
  MAR
  PISCINA
  JARDIN
  CIUDAD
  INTERIOR
}

model Unit {
  id                  String     @id @default(cuid())
  workspaceId         String
  workspace           Workspace  @relation(fields: [workspaceId], references: [id])
  projectId           String
  project             Project    @relation(fields: [projectId], references: [id])
  buildingId          String
  building            Building   @relation(fields: [buildingId], references: [id])
  // Identifier
  unitNumber          String // 1A, 201, PH-01
  floor               Int
  // Type
  type                String // Estudio, 1 Hab, 2 Hab, etc.
  bedrooms            Int        @default(0)
  bathrooms           Float      @default(0)
  squareMeters        Float
  terraceSquareMeters Float?
  // Pricing
  basePrice           Float
  currentPrice        Float
  // Characteristics
  view                UnitView?
  orientation         String? // N, S, E, W, NE, NO, SE, SO
  specialFeatures     String[]
  // Media
  floorPlan           String?
  photos              String[]
