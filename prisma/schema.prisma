  dueDate          DateTime
  paidDate         DateTime?
  method           PaymentMethod?
  proofUrl         String?
  status           SupplierPaymentStatus @default(PENDING)
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

// =====================================================================
// 32. AREA SUPERVISION
// =====================================================================

enum AreaStatus {
  NORMAL
  REQUIRES_ATTENTION
  CRITICAL
  INACTIVE
}

model AreaSupervision {
  id            String     @id @default(cuid())
  workspaceId   String
  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
  name          String
  projectId     String
  buildingId    String?
  description   String?
  responsibleId String?
  currentStatus AreaStatus @default(NORMAL)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  reports AreaReport[]
}

model AreaReport {
  id             String          @id @default(cuid())
  areaId         String
  area           AreaSupervision @relation(fields: [areaId], references: [id])
  reportDate     DateTime        @default(now())
  personnelCount Int
  activities     String          @db.Text
  incidents      String?
  photos         String[]
  status         AreaStatus
  notes          String?
  createdById    String
}

// =====================================================================
// 33. DELIVERY ACTS (Actas de Entrega)
// =====================================================================

enum DeliveryActStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  PENDING_SIGNATURE
  CANCELLED
}

model DeliveryActTemplate {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  checklistItems Json // [{item, required}, ...]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model DeliveryAct {
  id                         String            @id @default(cuid())
  workspaceId                String
  workspace                  Workspace         @relation(fields: [workspaceId], references: [id])
  unitId                     String
  customerId                 String
  scheduledDate              DateTime
  inspectorId                String?
  // Checklist
  checklistResults           Json // [{item, status, notes}, ...]
  // Observations
  generalObservations        String?           @db.Text
  // Media
  photos                     String[] // mín 5
  // Specifics
  meterReadings              String?
  keysDelivered              Int               @default(1)
  documentsDelivered         String?
  // Signatures
  clientSignatureUrl         String?
  representativeSignatureUrl String?
  clientSignedAt             DateTime?
  representativeSignedAt     DateTime?
  // Status
  status                     DeliveryActStatus @default(SCHEDULED)
  // PDF
  signedActUrl               String?
  // Metadata
  notes                      String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
}

// =====================================================================
// 34. WARRANTIES
// =====================================================================

enum WarrantyType {
  ESTRUCTURAL
  ELECTRICA
  PLOMERIA
  ACABADOS
  EQUIPOS
  OTRO
}

enum WarrantyStatus {
  REPORTED
  IN_EVALUATION
  IN_PROGRESS
  RESOLVED
  REJECTED
  ESCALATED
}

enum Priority {
  ALTA
  MEDIA
  BAJA
}

model Warranty {
  id               String         @id @default(cuid())
  workspaceId      String
  workspace        Workspace      @relation(fields: [workspaceId], references: [id])
  unitId           String
  unit             Unit           @relation(fields: [unitId], references: [id])
  customerId       String
  type             WarrantyType
  description      String         @db.Text
  // Media
  problemPhotos    String[]
  resolutionPhotos String[]
  // Reporting
  reportedAt       DateTime       @default(now())
  reportedByType   String // Cliente, Inspector, Asesor
  reportedById     String?
  // Resolution
  assignedToType   String? // Subcontratista, Proveedor
  assignedToId     String?
  deadline         DateTime?
  resolvedAt       DateTime?
  priority         Priority       @default(MEDIA)
  // Status
  status           WarrantyStatus @default(REPORTED)
  notes            String?
  // Metadata
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// =====================================================================
// 35. PUNCH LISTS
// =====================================================================

enum PunchListStatus {
  OPEN
  IN_PROGRESS
  NEAR_COMPLETE
  COMPLETED
}

enum PunchItemStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model PunchList {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  unitId          String
  unit            Unit            @relation(fields: [unitId], references: [id])
  customerId      String
  deliveryActId   String?
  responsibleId   String?
  generalDeadline DateTime?
  status          PunchListStatus @default(OPEN)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items PunchItem[]
}

model PunchItem {
  id              String          @id @default(cuid())
  punchListId     String
  punchList       PunchList       @relation(fields: [punchListId], references: [id])
  description     String
  location        String?
  problemPhoto    String?
  resolutionPhoto String?
  // Assignment
  responsibleType String? // Subcontratista, Proveedor
  responsibleId   String?
  priority        Priority        @default(MEDIA)
  deadline        DateTime?
  // Status
  status          PunchItemStatus @default(PENDING)
  resolvedAt      DateTime?
}

// =====================================================================
// 36. INTEGRATION CREDENTIALS (per workspace)
// =====================================================================

model IntegrationCredential {
  id          String   @id @default(cuid())
  workspaceId String
  // Type
  provider    String // twilio, evolution_api, retell, alterestate, meta, google
  scope       String // workspace, user
  userId      String? // if scope=user
  // Encrypted credentials
  credentials Json // encrypted at rest
  // Status
  isActive    Boolean  @default(true)
  // Provider-specific metadata
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =====================================================================
// 37. CUSTOM FIELDS DEFINITIONS
// =====================================================================

model CustomFieldDefinition {
  id          String   @id @default(cuid())
  workspaceId String
  entityType  String // contact, deal, unit, etc.
  key         String
  label       String
  fieldType   String // text, number, dropdown, multiselect, date, boolean
  options     Json? // for dropdowns
  isRequired  Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([workspaceId, entityType, key])
}

// =====================================================================
// 38. WHATSAPP CRM AGENT (manejo del CRM por WhatsApp)
// =====================================================================

model WhatsappCrmAction {
  id               String   @id @default(cuid())
  workspaceId      String
  userId           String // asesor que envió el mensaje
  // Input
  inputType        String // text, voice, image
  inputContent     String   @db.Text
  inputMediaUrl    String?
  transcribedText  String?
  // AI processing
  parsedIntent     Json // {actions: [...], summary: ""}
  // Confirmation
  confirmationSent Boolean  @default(false)
  userConfirmed    Boolean?
  // Execution
  executedActions  Json // [{action, status, result}, ...]
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  // Metadata
  createdAt        DateTime @default(now())
}

// =====================================================================
// END OF SCHEMA
