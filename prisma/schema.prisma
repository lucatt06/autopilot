// =====================================================================
// AUTOPILOT — SCHEMA DE DATOS (Prisma)
// Documento 2 de 3
// =====================================================================
//
// Este schema define todas las tablas de la base de datos PostgreSQL
// (Supabase) para Autopilot. Cada tabla con datos sensibles incluye
// workspace_id para Row-Level Security (RLS) multi-tenant.
//
// CONVENCIONES:
// - IDs: cuid() o uuid()
// - workspace_id: presente en cada tabla con datos de empresa
// - createdAt y updatedAt: automáticos
// - Soft-delete: deletedAt opcional donde aplique
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================================
// 1. WORKSPACES (Multi-tenancy)
// =====================================================================

model Workspace {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  logo           String?
  timezone       String    @default("America/Santo_Domingo")
  currency       String    @default("USD")
  language       String    @default("es")
  // Branding
  primaryColor   String?   @default("#2563EB")
  customDomain   String?
  // Status
  isActive       Boolean   @default(true)
  enabledModules String[]  @default(["crm", "real_estate"]) // crm, real_estate, productivity, website, etc.
  // Metadata
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  users             User[]
  contacts          Contact[]
  pipelines         Pipeline[]
  deals             Deal[]
  conversations     Conversation[]
  tasks             Task[]
  appointments      Appointment[]
  calendars         Calendar[]
  tags              Tag[]
  campaigns         Campaign[]
  aiAgents          AiAgent[]
  knowledgeBases    KnowledgeBase[]
  automations       Automation[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  projects          Project[]
  buildings         Building[]
  units             Unit[]
  blocks            Block[]
  reservations      Reservation[]
  sales             Sale[]
  paymentPlans      PaymentPlan[]
  payments          Payment[]
  contracts         Contract[]
  contractTemplates ContractTemplate[]
  commissions       Commission[]
  customers         Customer[]
  agencies          Agency[]
  staff             StaffMember[]
  workOrders        WorkOrder[]
  budgetItems       BudgetItem[]
  scheduleItems     ScheduleItem[]
  progressEntries   ProgressEntry[]
  inspections       Inspection[]
  subcontractors    Subcontractor[]
  suppliers         Supplier[]
  supplierPayments  SupplierPayment[]
  areaSupervisions  AreaSupervision[]
  deliveryActs      DeliveryAct[]
  warranties        Warranty[]
  punchLists        PunchList[]
  savedViews        SavedView[]
  projectStages     ProjectStage[]
}

// =====================================================================
// 2. USERS, ROLES & PERMISSIONS
// =====================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ASESOR
  CLIENTE
}

model User {
  id                        String     @id @default(cuid())
  workspaceId               String? // null = Super Admin (cross-workspace)
  workspace                 Workspace? @relation(fields: [workspaceId], references: [id])
  // Auth
  email                     String     @unique
  passwordHash              String?
  googleId                  String?    @unique
  // Profile
  firstName                 String
  lastName                  String
  avatar                    String?
  phone                     String?
  whatsappNumber            String?
  // Role
  role                      UserRole
  isActive                  Boolean    @default(true)
  // Personal config
  language                  String     @default("es")
  timezone                  String     @default("America/Santo_Domingo")
  // Onboarding
  onboardingCompleted       Boolean    @default(false)
  // Permissions (custom overrides over role defaults)
  canImpersonate            Boolean    @default(false)
  // Twilio
  twilioNumber              String?
  // Integrations
  googleCalendarConnected   Boolean    @default(false)
  googleCalendarToken       String? // encrypted
  facebookConnected         Boolean    @default(false)
  instagramConnected        Boolean    @default(false)
  whatsappPersonalConnected Boolean    @default(false)
  // Metadata
  lastLoginAt               DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  deletedAt                 DateTime?

  // Relations
  ownedContacts      Contact[]            @relation("ContactOwner")
  createdContacts    Contact[]            @relation("ContactCreator")
  assignedTasks      Task[]               @relation("TaskAssignee")
  createdTasks       Task[]               @relation("TaskCreator")
  appointments       Appointment[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  staffProfile       StaffMember?
  messages           Message[]
  UserFollowsContact UserFollowsContact[]
  savedViews         SavedView[]
}

// =====================================================================
// 2.5 SAVED VIEWS (Smart Lists)
// =====================================================================

/// Saved filter combinations the user pins as tabs (Smart Lists, Doc 1 §7.5).
/// Currently used for Contacts; entityType lets us extend to Deals, Units, etc.
model SavedView {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  /// "contact" | "deal" | "unit" | "task" | ...
  entityType  String
  /// Serialized filter spec (search, contactType, tagId, ownerId, source,
  /// createdFrom/To, sort, plus advanced filter conditions when applicable).
  filters     Json
  /// When true, other users in the same workspace can see and use this view.
  isShared    Boolean   @default(false)
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, userId, entityType])
}

model UserFollowsContact {
  userId     String
  contactId  String
  user       User     @relation(fields: [userId], references: [id])
  contact    Contact  @relation(fields: [contactId], references: [id])
  followedAt DateTime @default(now())

  @@id([userId, contactId])
}

// =====================================================================
// 3. CONTACTS
// =====================================================================

enum ContactType {
  LEAD
  PROSPECTO
  CLIENTE
  AGENTE_INMOBILIARIO
  REFERIDO
  OTRO
}

enum LeadTemperature {
  MUY_CALIENTE
  CALIENTE
  TIBIO
  FRIO
  SIN_CLASIFICAR
}

enum BuyPurpose {
  VIVIR
  INVERTIR
  AMBOS
  NO_DEFINIDO
}

enum PaymentPreference {
  CONTADO
  FINANCIAMIENTO_BANCARIO
  PLAN_DESARROLLADOR
  NO_DEFINIDO
}

enum Residency {
  RESIDENTE_LOCAL
  DOMINICANO_EXTERIOR
  EXTRANJERO
  NO_ESPECIFICADO
}

enum HardOwner {
  COMPANIA
  ASESOR
}

model Contact {
  id                   String             @id @default(cuid())
  workspaceId          String
  workspace            Workspace          @relation(fields: [workspaceId], references: [id])
  // Personal info
  firstName            String
  lastName             String
  email                String?
  emailVerified        Boolean            @default(false)
  mobilePhone          String? // Celular
  phone                String? // Teléfono fijo/secundario
  country              String?
  city                 String?
  language             String             @default("es")
  birthDate            DateTime?
  gender               String?
  photo                String?
  // Professional
  company              String?
  position             String?
  website              String?
  // Lead classification
  contactType          ContactType
  source               String?
  hardOwner            HardOwner?
  iaScore              Int                @default(0) // 0-100
  temperature          LeadTemperature    @default(SIN_CLASIFICAR)
  requiredAction       String?
  // Real estate interest
  interestedProjectIds String[] // refs to Project[]
  buyPurpose           BuyPurpose?
  unitTypes            String[] // multi: Estudio, 1 Hab, 2 Hab, etc.
  budgetMin            Float?
  budgetMax            Float?
  estimatedBuyTime     String? // Inmediato, 1-3 meses, etc.
  paymentPreference    PaymentPreference?
  residency            Residency?
  // Advanced classification
  currentStageId       String?
  currentStage         PipelineStage?     @relation(fields: [currentStageId], references: [id])
  nextStepDate         DateTime?
  nextStepUserId       String?
  movedTo              String?
  campaignOrigin       String?
  // AI agent
  activeAiAgentId      String?
  activeAiAgent        AiAgent?           @relation(fields: [activeAiAgentId], references: [id])
  killswitchIA         Boolean            @default(false)
  lastAiContactAt      DateTime?
  lastAiCallRecording  String?
  lastAiCallId         String?
  // DND
  dndAll               Boolean            @default(false)
  dndCalls             Boolean            @default(false)
  dndSms               Boolean            @default(false)
  dndEmail             Boolean            @default(false)
  dndIncoming          Boolean            @default(false)
  // Ownership
  ownerId              String?
  owner                User?              @relation("ContactOwner", fields: [ownerId], references: [id])
  createdById          String?
  createdBy            User?              @relation("ContactCreator", fields: [createdById], references: [id])
  // Metadata
  lastActivityAt       DateTime?
  lastChannelUsed      String?
  firstAttribution     String?
  lastAttribution      String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  // Relations
  deals         Deal[]
  conversations Conversation[]
  tasks         Task[]
  appointments  Appointment[]
  tags          ContactTag[]
  followers     UserFollowsContact[]
  customer      Customer?            @relation(fields: [customerId], references: [id])
  contracts     Contract[]
  notes         ContactNote[]
  documents     ContactDocument[]
  events        ContactEvent[]
  customFields  ContactCustomField[]
  customerId    String?
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])
  authorId  String?
  type      String   @default("manual") // manual, ai_call_transcript, system
  body      String   @db.Text
  createdAt DateTime @default(now())
}

model ContactDocument {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])
  uploadedBy String?
  category   String   @default("all") // all, internal, sent, received
  name       String
  url        String
  size       Int?
  mimeType   String?
  createdAt  DateTime @default(now())
}

model ContactEvent {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id])
  type        String // stage_change, opportunity_created, ai_call, etc.
  description String
  metadata    Json?
  performedBy String?
  createdAt   DateTime @default(now())
}

model ContactCustomField {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])
  fieldKey  String
  value     String  @db.Text
}

// =====================================================================
// 4. TAGS
// =====================================================================

model Tag {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  color       String    @default("#94A3B8")
  createdAt   DateTime  @default(now())

  contacts ContactTag[]

  @@unique([workspaceId, name])
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact  @relation(fields: [contactId], references: [id])
  tag       Tag      @relation(fields: [tagId], references: [id])
  taggedAt  DateTime @default(now())

  @@id([contactId, tagId])
}

// =====================================================================
// 5. PIPELINES & DEALS
// =====================================================================

model Pipeline {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stages PipelineStage[]
  deals  Deal[]
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  name       String
  position   Int
  color      String?
  isWon      Boolean  @default(false) // si esta etapa marca el negocio como ganado
  isLost     Boolean  @default(false) // si esta etapa marca el negocio como perdido

  deals    Deal[]
  contacts Contact[]
}

model Deal {
  id           String        @id @default(cuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  contactId    String
  contact      Contact       @relation(fields: [contactId], references: [id])
  pipelineId   String
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stageId      String
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  // Deal data
  name         String
  value        Float         @default(0)
  source       String?
  assignedToId String?
  isPrimary    Boolean       @default(true)
  // Status
  status       String        @default("active") // active, won, lost
  wonAt        DateTime?
  lostAt       DateTime?
  lostReason   String?
  // Metadata
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
}

// =====================================================================
// 6. CONVERSATIONS & MESSAGES
// =====================================================================

enum ConversationChannel {
  WHATSAPP_META
  WHATSAPP_EVOLUTION
  SMS
  EMAIL
  INSTAGRAM_DM
  FACEBOOK_MESSENGER
  INTERNAL
}

model Conversation {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  // Status
  isUnread      Boolean   @default(false)
  isStarred     Boolean   @default(false)
  isArchived    Boolean   @default(false)
  // Channels active in this conversation
  channels      String[]
  // Assignment
  assignedToId  String?
  // Metadata
  lastMessageAt DateTime?
  lastMessageBy String? // user or contact
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
  DOCUMENT
  CALL_RECORDING
  SYSTEM_EVENT
}

model Message {
  id               String              @id @default(cuid())
  conversationId   String
  conversation     Conversation        @relation(fields: [conversationId], references: [id])
  channel          ConversationChannel
  direction        MessageDirection
  type             MessageType
  // Content
  body             String?             @db.Text
  mediaUrl         String?
  mediaMimeType    String?
  // Call-specific
  callDuration     Int? // in seconds
  callRecordingUrl String?
  callTranscript   String?             @db.Text
  callSentiment    String?
  // Author
  sentByUserId     String?
  sentByUser       User?               @relation(fields: [sentByUserId], references: [id])
  sentByAiAgentId  String?
  fromName         String? // for inbound
  // Status
  status           String              @default("sent") // sent, delivered, read, failed
  externalId       String? // ID in Twilio/Meta/Retell
  // AI metadata
  aiCallId         String?
  aiEventData      Json? // structured event data from AI interactions
  // Scheduling
  scheduledFor     DateTime?
  // Metadata
  createdAt        DateTime            @default(now())
  readAt           DateTime?
}

// =====================================================================
// 7. CALENDARS & APPOINTMENTS
// =====================================================================

enum CalendarType {
  VIRTUAL
  PRESENCIAL
}

model Calendar {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id])
  name             String
  type             CalendarType
  isSystemDefault  Boolean      @default(false)
  // Settings
  generateMeetLink Boolean      @default(true)
  requireLocation  Boolean      @default(false)
  defaultLocation  String?
  // Distribution
  distribution     String       @default("round_robin") // round_robin, availability
  assignedUserIds  String[]
  // Metadata
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  appointments Appointment[]
}

enum AppointmentStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id              String            @id @default(cuid())
  workspaceId     String
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  calendarId      String
  calendar        Calendar          @relation(fields: [calendarId], references: [id])
  contactId       String?
  contact         Contact?          @relation(fields: [contactId], references: [id])
  userId          String // asesor asignado
  user            User              @relation(fields: [userId], references: [id])
  // Data
  title           String
  description     String?
  notes           String?
  // Time
  startTime       DateTime
  endTime         DateTime
  timezone        String
  // Type
  meetingType     CalendarType
  location        String?
  meetLink        String?
  // Invitees
  inviteeEmails   String[]
  // Status
  status          AppointmentStatus @default(CONFIRMED)
  // Reminders
  reminderSent24h Boolean           @default(false)
  reminderSent30m Boolean           @default(false)
  // External sync
  googleEventId   String?
  // Metadata
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// =====================================================================
// 8. TASKS
// =====================================================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id               String     @id @default(cuid())
  workspaceId      String
  workspace        Workspace  @relation(fields: [workspaceId], references: [id])
  title            String
  description      String?    @db.Text // rich text
  // Timing
  dueDate          DateTime?
  recurring        Boolean    @default(false)
  recurringPattern String? // cron-like
  // Assignment
  assignedToId     String?
  assignedTo       User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById      String
  createdBy        User       @relation("TaskCreator", fields: [createdById], references: [id])
  // Linked contacts (hasta 10)
  contactId        String?
  contact          Contact?   @relation(fields: [contactId], references: [id])
  // Status
  status           TaskStatus @default(PENDING)
  completedAt      DateTime?
  // Metadata
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// =====================================================================
// 9. CAMPAIGNS
// =====================================================================

model Campaign {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  name             String
  description      String?
  // Status
  isActive         Boolean   @default(true)
  // Participants (asesores en orden de round robin)
  participantIds   String[]
  participantOrder Json? // [{userId, order}, ...]
  // Source connections
  facebookAdId     String?
  googleAdId       String?
  webhookUrl       String?
  // Hard Owner config
  hardOwner        HardOwner @default(COMPANIA)
  // Metadata
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignments CampaignAssignment[]
}

model CampaignAssignment {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  contactId    String
  assignedToId String
  turnOrder    Int
  status       String   @default("active") // active, won, lost
  createdAt    DateTime @default(now())
}

// =====================================================================
// 10. AI AGENTS
// =====================================================================

enum AiAgentType {
  VOICE
  CHAT
}

enum AiAgentSubtype {
  CONVERSATION_FLOW
  SINGLE_PROMPT
  MULTI_PROMPT
  CUSTOM_LLM
}

model AiAgent {
  id                           String         @id @default(cuid())
  workspaceId                  String
  workspace                    Workspace      @relation(fields: [workspaceId], references: [id])
  // Identity
  name                         String
  type                         AiAgentType
  subtype                      AiAgentSubtype
  // Model
  model                        String         @default("claude-sonnet-4")
  temperature                  Float          @default(0.7)
  // Prompts
  systemPrompt                 String         @db.Text
  welcomeMessage               String?
  // Behavior
  startsSpeakingAfterSilenceMs Int            @default(1500)
  // Voice-specific
  voiceId                      String? // ElevenLabs voice ID
  voiceLanguage                String?
  // Chat-specific
  waitTimeMs                   Int            @default(3000) // buffer mensajes
  maxResponses                 Int            @default(50)
  sleepMode                    Boolean        @default(false)
  purposefulMisspellings       Boolean        @default(false)
  misspellingProbability       Float          @default(0.0)
  responseChannels             String[]
  pauseOnHumanReply            Boolean        @default(true)
  autoFollowUpAutomationId     String?
  // Knowledge & functions
  knowledgeBaseId              String?
  knowledgeBase                KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id])
  functions                    Json? // array of function definitions
  // Retell sync
  retellAgentId                String?        @unique
  retellSyncedAt               DateTime?
  // Webhook
  webhookUrl                   String?
  // Status
  isActive                     Boolean        @default(true)
  // Metadata
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  activeContacts Contact[]
  routings       AgentRouting[]
}

model KnowledgeBase {
  id                String    @id @default(cuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id])
  name              String
  description       String?
  // Vector storage
  pineconeIndex     String?
  pineconeNamespace String?
  // Metadata
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  entries KnowledgeEntry[]
  agents  AiAgent[]
}

model KnowledgeEntry {
  id               String        @id @default(cuid())
  knowledgeBaseId  String
  knowledgeBase    KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id])
  // Type
  type             String // text, faq, file, url
  title            String
  content          String        @db.Text
  fileUrl          String?
  sourceUrl        String?
  // Metadata filtering — clave para no mezclar info entre proyectos
  projectId        String?
  metadata         Json?
  // Embedding info
  pineconeVectorId String?
  // Metadata
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AgentRouting {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String
  agent       AiAgent  @relation(fields: [agentId], references: [id])
  priority    Int
  conditions  Json // [{field, operator, value}, ...]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AiCall {
  id                   String           @id @default(cuid())
  workspaceId          String
  contactId            String?
  agentId              String?
  retellCallId         String           @unique
  // Direction
  direction            MessageDirection
  fromNumber           String
  toNumber             String
  // Duration
  startedAt            DateTime
  endedAt              DateTime?
  durationSeconds      Int?
  // Result (structured event data)
  result               String? // voicemail, no_answer, answered, completed
  hangupReason         String?
  appointmentScheduled Boolean          @default(false)
  sentiment            String? // positive, neutral, negative
  detectedInterest     String? // high, medium, low
  mentionedProject     String?
  suggestedNextAction  String?
  // Content
  transcript           String?          @db.Text
  summary              String?          @db.Text
  recordingUrl         String?
  // Cost
  cost                 Float?
  // Metadata
  createdAt            DateTime         @default(now())
}

// =====================================================================
// 11. AUTOMATIONS
// =====================================================================

model Automation {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  name          String
  description   String?
  isActive      Boolean   @default(true)
  // Trigger
  triggerType   String // contact_created, stage_changed, ai_no_response, etc.
  triggerConfig Json
  // Canvas
  canvasData    Json // nodes, edges, sticky notes
  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  executions AutomationExecution[]
}

model AutomationExecution {
  id            String     @id @default(cuid())
  automationId  String
  automation    Automation @relation(fields: [automationId], references: [id])
  contactId     String?
  triggerData   Json
  status        String     @default("running") // running, completed, failed, paused
  currentNodeId String?
  executionLog  Json // step-by-step log
  startedAt     DateTime   @default(now())
  completedAt   DateTime?
  error         String?
}

// =====================================================================
// 12. NOTIFICATIONS
// =====================================================================

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  // Content
  type        String // new_message, task_overdue, etc.
  title       String
  body        String?
  link        String?
  // Channel delivered
  inApp       Boolean   @default(true)
  push        Boolean   @default(false)
  email       Boolean   @default(false)
  whatsapp    Boolean   @default(false)
  // Status
  isRead      Boolean   @default(false)
  readAt      DateTime?
  // Related entity
