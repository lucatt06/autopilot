  EN_CONSTRUCCION
  ENTREGADO
  SUSPENDIDO
}

enum ProjectType {
  RESIDENCIAL
  COMERCIAL
  MIXTO
}

model Project {
  id                   String        @id @default(cuid())
  workspaceId          String
  workspace            Workspace     @relation(fields: [workspaceId], references: [id])
  name                 String
  type                 ProjectType
  location             String?
  address              String?
  // Geographic detail (Doc 1 §8.2 — supports province / city / sector breakdown)
  province             String?
  city                 String?
  sector               String?
  // Amenities / "Características" — free-form catalog per workspace
  amenities            String[]      @default([])
  // Media
