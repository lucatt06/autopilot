model PaymentPlanTemplate {
  id                       String   @id @default(cuid())
  workspaceId              String
  projectId                String?
  project                  Project? @relation(fields: [projectId], references: [id])
  name                     String
  // Sections (% of total price)
  reservationAmount        Float? // absolute, not %
  initialPercent           Float
  constructionPercent      Float
  finalPercent             Float
  // Construction installments
  constructionInstallments Int      @default(12)
  constructionPeriodicity  String   @default("monthly") // monthly, bimonthly, quarterly
  // Validation: sum should be 100%
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
}

model PaymentPlan {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  saleId             String    @unique
  sale               Sale      @relation(fields: [saleId], references: [id])
  templateId         String?
  // Totals
  totalPrice         Float
  totalPaid          Float     @default(0)
  // Sections breakdown
  reservationAmount  Float
  initialAmount      Float
  constructionAmount Float
  finalAmount        Float
  // Metadata
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  installments PaymentInstallment[]
  payments     Payment[]
}

