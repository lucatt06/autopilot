# =====================================================================
# AUTOPILOT — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =====================================================================

# ---------------------------------------------------------------------
# 🔴 PRIORIDAD 1 — Necesarias para Fase 1A (Fundación)
# ---------------------------------------------------------------------

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Supabase (BD + Auth + Storage + RLS)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_REF=""
SUPABASE_ACCESS_TOKEN=""

# Database (Prisma → Supabase Postgres)
DATABASE_URL=""
DIRECT_URL=""

# Anthropic Claude (agentes + IA Asistente + WhatsApp CRM Agent)
ANTHROPIC_API_KEY=""

# Auth secret (NextAuth / sesión)
AUTH_SECRET=""

# ---------------------------------------------------------------------
# 🟡 PRIORIDAD 2 — Fase 1D (Integraciones, ~mes 2-3)
# ---------------------------------------------------------------------

# Twilio (voz + SMS + softphone + pools outbound IA)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Evolution API (WhatsApp personal por asesor) — alojado en Railway
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# Meta Business API (WhatsApp oficial empresa)
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN=""
META_PHONE_NUMBER_ID=""
META_WABA_ID=""

# Google OAuth (Login + Calendar bidireccional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# Facebook / Instagram (messaging + Lead Ads)
FB_APP_ID=""
FB_APP_SECRET=""
FB_WEBHOOK_VERIFY_TOKEN=""

# Resend (email transaccional)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# AlterEstate (Red Inmobiliaria — credenciales cifradas en BD por workspace)
ALTERESTATE_BASE_URL="https://app.alterestate.com/trexo"

# ---------------------------------------------------------------------
# 🟢 PRIORIDAD 3 — Fase 1E (IA, ~mes 3-4)
# ---------------------------------------------------------------------

# OpenAI (embeddings + Whisper)
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Pinecone (Vector DB — namespaces por workspaceId)
PINECONE_API_KEY=""
PINECONE_INDEX="autopilot-kb"
PINECONE_ENVIRONMENT=""

# Retell AI (agentes de voz)
RETELL_API_KEY=""
RETELL_WEBHOOK_SECRET=""

# ElevenLabs (TTS Flash v2.5)
ELEVENLABS_API_KEY=""
ELEVENLABS_DEFAULT_VOICE_ID=""

# Upstash Redis (cache + colas)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ClickHouse Cloud (analytics OLAP en tiempo real)
CLICKHOUSE_URL=""
CLICKHOUSE_USER=""
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DATABASE="autopilot"

# Railway (host Evolution API auxiliar)
RAILWAY_TOKEN=""

# ---------------------------------------------------------------------
# 🔐 Encriptación de credenciales por workspace (AES-256)
# ---------------------------------------------------------------------
ENCRYPTION_KEY=""  # 32 bytes random — generar con: openssl rand -hex 32

# ---------------------------------------------------------------------
# 📊 Observability (opcional pero recomendado)
# ---------------------------------------------------------------------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
